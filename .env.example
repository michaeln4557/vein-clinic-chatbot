# Database
DATABASE_URL=postgresql://vein_clinic:dev_password@localhost:5432/vein_clinic
POSTGRES_PASSWORD=dev_password

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=change_this_to_a_secure_random_string

# Twilio SMS Integration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# AI Provider (choose one or both)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Application
NODE_ENV=development
LOG_LEVEL=info
PORT=3001
ADMIN_UI_PORT=3000

# File Upload (S3-compatible)
S3_BUCKET=vein-clinic-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# CRM Integration
CRM_API_URL=https://your-crm-api.example.com
CRM_API_KEY=your_crm_api_key

# Scheduling Integration
SCHEDULING_API_URL=https://your-scheduling-api.example.com
SCHEDULING_API_KEY=your_scheduling_api_key
