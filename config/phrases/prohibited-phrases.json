{
  "phrase_library_id": "prohibited-phrases",
  "version": "1.1.0",
  "name": "Prohibited Phrase Library",
  "description": "Phrases that must never be used by the chatbot under any circumstances. Organized by violation category with severity levels for enforcement.",
  "enforcement": "absolute",
  "categories": {
    "insurance": [
      {
        "id": "prohib-ins-001",
        "category": "insurance",
        "text": "free",
        "reason": "Implies zero cost without verified benefits. Cannot guarantee any service is free.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-002",
        "category": "insurance",
        "text": "complimentary",
        "reason": "Synonym for 'free' — implies no charge without verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-003",
        "category": "insurance",
        "text": "guaranteed",
        "reason": "Cannot guarantee insurance coverage, cost, or outcomes.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-004",
        "category": "insurance",
        "text": "covered",
        "reason": "Definitive coverage statements require verification. Cannot state that any plan covers any service.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-005",
        "category": "insurance",
        "text": "no cost",
        "reason": "Implies zero patient responsibility. Exception: 'no cost or obligation for the verification' only.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-006",
        "category": "insurance",
        "text": "no charge",
        "reason": "Implies zero cost for services or procedures.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-007",
        "category": "insurance",
        "text": "fully covered",
        "reason": "Cannot confirm full coverage without verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-008",
        "category": "insurance",
        "text": "your plan covers",
        "reason": "Cannot state what any specific plan covers before verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-009",
        "category": "insurance",
        "text": "your insurance covers",
        "reason": "Cannot confirm what insurance covers without verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-010",
        "category": "insurance",
        "text": "don't worry about cost",
        "reason": "Dismisses legitimate financial concern and implies zero or low cost.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-011",
        "category": "insurance",
        "text": "won't cost you anything",
        "reason": "Explicit zero-cost promise without verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-012",
        "category": "insurance",
        "text": "zero out of pocket",
        "reason": "Cannot guarantee out-of-pocket costs.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-013",
        "category": "insurance",
        "text": "100% covered",
        "reason": "Specific coverage percentages cannot be stated.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-014",
        "category": "insurance",
        "text": "insurance will take care of",
        "reason": "Implies definite coverage and zero patient responsibility.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-015",
        "category": "insurance",
        "text": "your copay will be",
        "reason": "Cannot specify copay amounts without verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-016",
        "category": "insurance",
        "text": "your deductible is",
        "reason": "Cannot specify deductible amounts without verification.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-017",
        "category": "insurance",
        "text": "most people don't pay anything",
        "reason": "Misleading generalization about cost.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-018",
        "category": "insurance",
        "text": "insurance always covers this",
        "reason": "False absolute statement about coverage.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-ins-019",
        "category": "insurance",
        "text": "usually covered",
        "reason": "Implies likely coverage without verification.",
        "severity": "warn",
        "active": true
      },
      {
        "id": "prohib-ins-020",
        "category": "insurance",
        "text": "nothing to pay",
        "reason": "Implies zero patient cost.",
        "severity": "block",
        "active": true
      }
    ],
    "clinical": [
      {
        "id": "prohib-clin-001",
        "category": "clinical",
        "text": "you have [condition]",
        "reason": "Constitutes a diagnosis. Only licensed physicians may diagnose.",
