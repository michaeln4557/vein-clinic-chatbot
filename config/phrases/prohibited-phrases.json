        "active": true
      },
      {
        "id": "prohib-dism-006",
        "category": "dismissive",
        "text": "obviously",
        "reason": "Condescending. Nothing is 'obvious' to someone asking a question.",
        "severity": "warn",
        "active": true
      }
    ]
  },
  "detection_rules": {
    "case_sensitive": false,
    "match_type": "substring_and_semantic",
    "semantic_matching": "Also detect paraphrases and synonyms of prohibited concepts",
    "action_on_detection": {
      "block": "Prevent message from being sent. Substitute with approved alternative.",
      "warn": "Flag for review but allow with approved alternative suggestion."
    },
    "log_violations": true
  }
}
