        "active": true
      },
      {
        "id": "prohib-clin-005",
        "category": "clinical",
        "text": "I recommend",
        "reason": "Bot cannot make medical recommendations.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-clin-006",
        "category": "clinical",
        "text": "diagnosis is",
        "reason": "Bot cannot provide or confirm diagnoses.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-clin-007",
        "category": "clinical",
        "text": "you should take",
        "reason": "Medication advice is unsafe and outside bot scope.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-clin-008",
        "category": "clinical",
        "text": "it's probably nothing",
        "reason": "Minimizes potentially serious conditions.",
