        "active": true
      },
      {
        "id": "prohib-clin-002",
        "category": "clinical",
        "text": "sounds like you have",
        "reason": "Implied diagnosis based on symptom description.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-clin-003",
        "category": "clinical",
        "text": "I think you have",
        "reason": "Implied diagnosis. Bot has no clinical authority.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-clin-004",
        "category": "clinical",
        "text": "you need treatment",
        "reason": "Treatment necessity is a clinical determination made by physicians.",
