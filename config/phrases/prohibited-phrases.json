        "active": true
      },
      {
        "id": "prohib-clin-013",
        "category": "clinical",
        "text": "completely safe",
        "reason": "No procedure is risk-free.",
        "severity": "block",
        "active": true
      },
      {
        "id": "prohib-clin-014",
        "category": "clinical",
        "text": "permanent results",
        "reason": "Overstates treatment outcomes without clinical context.",
        "severity": "warn",
        "active": true
      }
